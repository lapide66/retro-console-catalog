{
  "name": "retro-console-catalog",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "android:mobile": "npm --workspace apps/mobile run android",
    "ios:mobile": "npm --workspace apps/mobile run ios"
  }
}
